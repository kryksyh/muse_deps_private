function(_crashpad_find_static_lib out name)
    set(_hints "")
    find_program(_cc NAMES cc gcc clang)
    if(_cc)
        execute_process(COMMAND "${_cc}" -print-multiarch
                        OUTPUT_VARIABLE _multiarch ERROR_QUIET
                        OUTPUT_STRIP_TRAILING_WHITESPACE)
        if(_multiarch)
            list(APPEND _hints "/usr/lib/${_multiarch}")
        endif()
    endif()
    set(_old_suffixes "${CMAKE_FIND_LIBRARY_SUFFIXES}")
    set(CMAKE_FIND_LIBRARY_SUFFIXES ".a")
    set(_var "_crashpad_${name}_lib")
    unset(${_var} CACHE)
    if(_hints)
        find_library(${_var} NAMES "${name}" PATHS ${_hints} NO_DEFAULT_PATH)
    endif()
    if(NOT ${_var})
        unset(${_var} CACHE)
        find_library(${_var} NAMES "${name}" REQUIRED)
    endif()
    set(_lib "${${_var}}")
    unset(${_var} CACHE)
    set(CMAKE_FIND_LIBRARY_SUFFIXES "${_old_suffixes}")
    if(NOT _lib MATCHES "\\.a$")
        message(FATAL_ERROR "[${BD_NAME}] expected static ${name}, got: ${_lib}")
    endif()
    set(${out} "${_lib}" PARENT_SCOPE)
endfunction()


# Link to openssl statically, so we don't have to bundle them, and worry about their versions on linux
function(_crashpad_use_static_openssl)
    _crashpad_find_static_lib(_ssl "ssl")
    _crashpad_find_static_lib(_crypto "crypto")
    set(_file "${SRC}/util/BUILD.gn")
    file(READ "${_file}" _gn)
    set(_old "        libs = [
          \"crypto\",
          \"ssl\",
        ]")
    set(_new "        libs = [
          \"${_ssl}\",
          \"${_crypto}\",
        ]")
    string(REPLACE "${_old}" "${_new}" _patched "${_gn}")
    if(_patched STREQUAL _gn)
        message(FATAL_ERROR "[${BD_NAME}] failed to patch util/BUILD.gn for static OpenSSL")
    endif()
    file(WRITE "${_file}" "${_patched}")
endfunction()

if(BD_OS STREQUAL "linux")
    _crashpad_use_static_openssl()
endif()

function(_crashpad_select_gn out)
    if(BD_OS STREQUAL "windows")
        set(_exe "${BUILD}/gn-tools/${_wanted_gn_sub}/gn.exe")
    else()
        set(_exe "${BUILD}/gn-tools/${_wanted_gn_sub}/gn")
    endif()
    if(NOT EXISTS "${_exe}")
        message(FATAL_ERROR "[${BD_NAME}] GN not staged: ${_exe}")
    endif()
    if(NOT BD_OS STREQUAL "windows")
        file(CHMOD "${_exe}"
             PERMISSIONS OWNER_READ OWNER_WRITE OWNER_EXECUTE
                         GROUP_READ GROUP_EXECUTE WORLD_READ WORLD_EXECUTE)
    endif()
    set(${out} "${_exe}" PARENT_SCOPE)
endfunction()

