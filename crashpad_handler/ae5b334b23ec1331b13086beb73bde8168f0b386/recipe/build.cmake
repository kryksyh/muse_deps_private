function(_crashpad_select_gn_sub out)
    if(BD_OS STREQUAL "linux")
        if(BD_ARCH STREQUAL "aarch64")
            set(_sub "gn-linux-arm64")
        else()
            set(_sub "gn-linux-amd64")
        endif()
    elseif(BD_OS STREQUAL "macos")
        cmake_host_system_information(RESULT _host_cpu QUERY OS_PLATFORM)
        if(_host_cpu MATCHES "arm64|aarch64")
            set(_sub "gn-mac-arm64")
        else()
            set(_sub "gn-mac-amd64")
        endif()
    elseif(BD_OS STREQUAL "windows")
        set(_sub "gn-windows-amd64")
    else()
        message(FATAL_ERROR "[${BD_NAME}] unsupported OS: ${BD_OS}")
    endif()
    set(${out} "${_sub}" PARENT_SCOPE)
endfunction()

function(_crashpad_archive_ext basename out)
    if(basename MATCHES "\\.(tar\\.gz|tar\\.xz|tar\\.bz2|tgz|zip)$")
        set(${out} "${CMAKE_MATCH_1}" PARENT_SCOPE)
    else()
        get_filename_component(_e "${basename}" LAST_EXT)
        string(REGEX REPLACE "^\\." "" _e "${_e}")
        set(${out} "${_e}" PARENT_SCOPE)
    endif()
endfunction()

_crashpad_select_gn_sub(_wanted_gn_sub)

function(_crashpad_clang_sub out)
    if(BD_OS STREQUAL "linux")
        if(BD_ARCH STREQUAL "aarch64")
            set(_sub "clang-linux-arm64")
        else()
            set(_sub "clang-linux-amd64")
        endif()
    elseif(BD_OS STREQUAL "windows")
        set(_sub "clang-windows-amd64")
    else()
        set(_sub "")
    endif()
    set(${out} "${_sub}" PARENT_SCOPE)
endfunction()
_crashpad_clang_sub(_wanted_clang_sub)

function(_crashpad_stage_source sub url sha dest)
    get_filename_component(_an "${url}" NAME)
    if(_an MATCHES "^git_revision:")
        set(_an "${BD_NAME}-${sub}.zip")
    else()
        _crashpad_archive_ext("${_an}" _cache_ext)
        set(_an "${BD_NAME}-${sub}.${_cache_ext}")
    endif()
    set(_dl "${BD_CACHE}/downloads/${BD_NAME}")
    set(_archive "${_dl}/${_an}")
    if(NOT EXISTS "${_archive}")
        file(MAKE_DIRECTORY "${_dl}")
        set(_urls "${url}")
        get_filename_component(_repo "${BD_RECIPE_DIR}/../../.." ABSOLUTE)
        _bd_mirror("${_repo}" _mirror)
        if(_mirror)
            _crashpad_archive_ext("${_an}" _ext)
            list(APPEND _urls "${_mirror}/${BD_NAME}-${sub}-src.${_ext}")
        endif()
        _bd_fetch("${_archive}" "${sha}" ${_urls})
    else()
        file(SHA256 "${_archive}" _got)
        if(NOT _got STREQUAL "${sha}")
            message(FATAL_ERROR "[${BD_NAME}] cached ${_an} SHA256 mismatch: ${_got} != ${sha}")
        endif()
    endif()

    set(_extract "${BUILD}/extract-${sub}")
    file(REMOVE_RECURSE "${_extract}" "${dest}")
    file(MAKE_DIRECTORY "${_extract}" "${dest}")
    file(ARCHIVE_EXTRACT INPUT "${_archive}" DESTINATION "${_extract}")
    file(GLOB _top LIST_DIRECTORIES true "${_extract}/*")
    list(LENGTH _top _n)
    if(_n EQUAL 1)
        list(GET _top 0 _root)
        if(IS_DIRECTORY "${_root}")
            file(COPY "${_root}/" DESTINATION "${dest}")
            return()
        endif()
    endif()
    file(COPY "${_extract}/" DESTINATION "${dest}")
endfunction()

function(_crashpad_stage_git sub repo commit dest)
    set(_gitdir "${BD_CACHE}/downloads/${BD_NAME}/${sub}.git")
    file(MAKE_DIRECTORY "${BD_CACHE}/downloads/${BD_NAME}")
    if(NOT EXISTS "${_gitdir}/.git")
        _bd_run(${GIT} clone --quiet "${repo}" "${_gitdir}")
    endif()
    _bd_run_dir("${_gitdir}" ${GIT} fetch --quiet origin "${commit}")
    _bd_run_dir("${_gitdir}" ${GIT} checkout --quiet "${commit}")
    execute_process(COMMAND ${GIT} -C "${_gitdir}" rev-parse HEAD
                    OUTPUT_VARIABLE _head OUTPUT_STRIP_TRAILING_WHITESPACE
                    RESULT_VARIABLE _rc)
    if(NOT _rc EQUAL 0 OR NOT _head STREQUAL "${commit}")
        message(FATAL_ERROR "[${BD_NAME}] ${sub}: HEAD ${_head} != pinned ${commit}")
    endif()
    file(REMOVE_RECURSE "${dest}")
    file(MAKE_DIRECTORY "${dest}")
    file(COPY "${_gitdir}/" DESTINATION "${dest}" PATTERN ".git" EXCLUDE)
endfunction()

foreach(_entry ${DEP_SOURCES})
    string(REPLACE "|" ";" _parts "${_entry}")
    list(GET _parts 0 _sub)
    list(GET _parts 1 _kind)
    list(GET _parts 2 _url)
    list(GET _parts 3 _sha)
    if(_sub STREQUAL "mini_chromium")
        _crashpad_stage_source("${_sub}" "${_url}" "${_sha}" "${SRC}/third_party/mini_chromium/mini_chromium")
    elseif(_sub STREQUAL "zlib")
        if(BD_OS STREQUAL "windows")
            _crashpad_stage_git("${_sub}" "${_url}" "${_sha}" "${SRC}/third_party/zlib/zlib")
        endif()
    elseif(_sub MATCHES "^gn-")
        if(NOT _kind STREQUAL "tarball")
            message(FATAL_ERROR "[${BD_NAME}] unsupported GN source kind for ${_sub}: ${_kind}")
        endif()
        if(_sub STREQUAL "${_wanted_gn_sub}")
            _crashpad_stage_source("${_sub}" "${_url}" "${_sha}" "${BUILD}/gn-tools/${_sub}")
        endif()
    elseif(_sub MATCHES "^clang-")
        if(_sub STREQUAL "${_wanted_clang_sub}")
            _crashpad_stage_source("${_sub}" "${_url}" "${_sha}" "${BUILD}/clang-tools/${_sub}")
        endif()
    else()
        message(FATAL_ERROR "[${BD_NAME}] unknown child source: ${_sub}")
    endif()
endforeach()

