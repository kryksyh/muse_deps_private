function(_crashpad_build_one arch outdir)
    if(arch STREQUAL "aarch64")
        set(_cpu "arm64")
    elseif(arch STREQUAL "x86_64")
        set(_cpu "x64")
    else()
        message(FATAL_ERROR "[${BD_NAME}] unsupported arch: ${arch}")
    endif()

    set(_args "is_debug=false target_cpu=\"${_cpu}\"")
    if(BD_OS STREQUAL "linux")
        string(APPEND _args " use_sysroot=false")
        string(APPEND _args " crashpad_http_transport_impl=\"socket\"")
        string(APPEND _args " crashpad_use_boringssl_for_http_transport_socket=true")
    endif()

    _crashpad_clang_sub(_clang_sub)
    if(NOT _clang_sub STREQUAL "")
        set(_clang_dir "${BUILD}/clang-tools/${_clang_sub}")
        if(BD_OS STREQUAL "windows")
            set(_clang_probe "${_clang_dir}/bin/clang-cl.exe")
        else()
            set(_clang_probe "${_clang_dir}/bin/clang")
        endif()
        if(NOT EXISTS "${_clang_probe}")
            message(FATAL_ERROR "[${BD_NAME}] clang not staged: ${_clang_probe}")
        endif()
        string(APPEND _args " clang_path=\"${_clang_dir}\"")
    endif()

    _bd_run_dir("${SRC}" "${GN}" gen "${outdir}" "--args=${_args}")
    _bd_run_dir("${SRC}" "${NINJA}" -C "${outdir}" handler:crashpad_handler)
endfunction()

