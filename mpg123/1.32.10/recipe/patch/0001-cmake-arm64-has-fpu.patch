ARMv8 mandates an FPU; the HAS_FPU host query reads /proc/cpuinfo flags, which
arm64 Linux does not report, yielding fixed-point + NEON64 float asm (#error).
--- a/ports/cmake/src/CMakeLists.txt
+++ b/ports/cmake/src/CMakeLists.txt
@@ -194,7 +194,7 @@ check_cpu_arch_x64(ARCH_IS_X64)
 check_cpu_arch_arm32(ARCH_IS_ARM32)
 check_cpu_arch_arm64(ARCH_IS_ARM64)
 
-if(WIN32 OR (ARCH_IS_ARM64 AND APPLE))
+if(WIN32 OR ARCH_IS_ARM64)
     set(HAVE_FPU 1)
 else()
     cmake_host_system_information(RESULT HAVE_FPU QUERY HAS_FPU)
